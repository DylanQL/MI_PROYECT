<%- include('partials/head', { title: isAdminLogin ? 'Admin | DataPilot MVC' : 'Login | DataPilot MVC' }) %>

<main class="auth-shell">
  <section class="auth-card glass">
    <div class="auth-brand">
      <i class="bi bi-database-check"></i>
      <h1><%= isAdminLogin ? 'Panel administrador' : 'DataPilot MVC' %></h1>
      <p><%= isAdminLogin ? 'Acceso exclusivo para gestionar cuentas de la plataforma' : 'Gestiona tus tablas MySQL con WebSocket en tiempo real' %></p>
    </div>

    <% if (error) { %>
      <div class="alert error"><i class="bi bi-exclamation-octagon"></i> <%= error %></div>
    <% } %>

    <form method="POST" action="<%= formAction || '/login' %>" class="auth-form">
      <label>
        Usuario o correo
        <input type="text" name="username" placeholder="usuario o correo" required />
      </label>
      <label>
        Contrasena
        <input type="password" name="password" placeholder="********" required />
      </label>
      <button type="submit" class="btn btn-primary">
        <i class="bi bi-box-arrow-in-right"></i>
        Ingresar
      </button>
    </form>
  </section>
</main>

<%- include('partials/footer') %>
