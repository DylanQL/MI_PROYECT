<%- include('partials/head', { title: 'Dashboard | DataPilot MVC' }) %>

<header class="topbar">
  <div class="brand"><i class="bi bi-layers-half"></i> DataPilot MVC</div>
  <nav>
    <a href="/profile" class="btn btn-ghost"><i class="bi bi-person"></i> Perfil</a>
    <form method="POST" action="/logout" class="inline-form">
      <button class="btn btn-danger" type="submit"><i class="bi bi-box-arrow-left"></i> Salir</button>
    </form>
  </nav>
</header>

<main class="container">
  <aside class="panel menu-panel">
    <h2><i class="bi bi-list-check"></i> Menu de opciones</h2>
    <div class="menu-list">
      <button class="menu-item active" data-section="selectTable"><i class="bi bi-table"></i> Seleccionar tabla</button>
      <button class="menu-item" data-section="createTable"><i class="bi bi-plus-square"></i> Crear tabla</button>
      <button class="menu-item" data-section="editTable"><i class="bi bi-pencil-square"></i> Editar tabla</button>
      <button class="menu-item" data-section="deleteTable"><i class="bi bi-trash3"></i> Borrar tabla</button>
      <button class="menu-item" data-section="addRecord"><i class="bi bi-node-plus"></i> Anadir registro</button>
      <button class="menu-item" data-section="foreignKeys"><i class="bi bi-link-45deg"></i> Vincular tablas (FK)</button>
    </div>
  </aside>

  <section class="content-grid">
    <article id="selectTable" class="panel section-panel active">
      <div class="section-title">
        <h3><i class="bi bi-table"></i> Seleccionar tabla</h3>
        <select id="tableSelect"></select>
      </div>

      <div class="filters-head">
        <h4>Filtros ilimitados</h4>
        <div class="toolbar-actions">
          <button id="addFilterBtn" class="btn btn-ghost"><i class="bi bi-funnel"></i> Agregar filtro</button>
          <button id="clearFiltersBtn" class="btn btn-ghost"><i class="bi bi-x-circle"></i> Limpiar filtros</button>
        </div>
      </div>
      <div id="filtersContainer" class="filters"></div>

      <div class="table-wrap">
        <table id="recordsTable"></table>
      </div>

      <div class="pagination">
        <label class="page-size-control">
          Registros por pagina
          <select id="pageSizeSelect">
            <option value="10">10</option>
            <option value="25">25</option>
            <option value="50">50</option>
            <option value="100">100</option>
          </select>
        </label>
        <button id="prevPage" class="btn btn-ghost"><i class="bi bi-arrow-left"></i> Anterior</button>
        <span id="pageInfo">Pagina 1</span>
        <button id="nextPage" class="btn btn-ghost">Siguiente <i class="bi bi-arrow-right"></i></button>
        <button id="reloadRecordsBtn" class="btn btn-ghost"><i class="bi bi-arrow-clockwise"></i> Recargar</button>
      </div>
    </article>

    <article id="createTable" class="panel section-panel">
      <h3><i class="bi bi-plus-square"></i> Crear tabla</h3>
      <form id="createTableForm" class="grid-form">
        <label>
          Nombre de tabla
          <input type="text" name="tableName" placeholder="productos" required />
        </label>
        <div id="createColumnsContainer"></div>
        <button type="button" id="addCreateColumn" class="btn btn-ghost"><i class="bi bi-plus-lg"></i> Agregar campo</button>
        <button type="submit" class="btn btn-primary"><i class="bi bi-check2-circle"></i> Crear tabla</button>
      </form>
    </article>

    <article id="editTable" class="panel section-panel">
      <h3><i class="bi bi-pencil-square"></i> Editar tabla</h3>
      <form id="editTableForm" class="grid-form">
        <label>
          Tabla
          <select name="tableName" id="editTableSelect" required></select>
        </label>
        <label>
          Accion
          <select name="action" id="editAction" required>
            <option value="add">Agregar campo</option>
            <option value="modify">Modificar campo</option>
            <option value="drop">Borrar campo</option>
          </select>
        </label>
        <label id="oldNameWrap">
          Campo actual
          <input type="text" name="oldName" placeholder="campo_actual" />
        </label>
        <label>
          Nombre de campo
          <input type="text" name="name" placeholder="nuevo_campo" required />
        </label>
        <label id="typeWrap">
          Tipo
          <select name="type" id="editType"></select>
        </label>
        <label id="nullableWrap" class="check-label">
          <input type="checkbox" name="nullable" /> Permitir NULL
        </label>
        <button type="submit" class="btn btn-primary"><i class="bi bi-floppy"></i> Aplicar cambios</button>
      </form>
    </article>

    <article id="deleteTable" class="panel section-panel">
      <h3><i class="bi bi-trash3"></i> Borrar tabla</h3>
      <form id="deleteTableForm" class="grid-form">
        <label>
          Tabla a borrar
          <select name="tableName" id="deleteTableSelect" required></select>
        </label>
        <button type="submit" class="btn btn-danger"><i class="bi bi-trash3"></i> Eliminar tabla</button>
      </form>
    </article>

    <article id="addRecord" class="panel section-panel">
      <h3><i class="bi bi-node-plus"></i> Anadir registro</h3>
      <form id="recordForm" class="grid-form">
        <label>
          Tabla
          <select name="tableName" id="recordTableSelect" required></select>
        </label>
        <div id="recordFields"></div>
        <button type="submit" class="btn btn-primary"><i class="bi bi-plus-circle"></i> Guardar registro</button>
      </form>
    </article>

    <article id="foreignKeys" class="panel section-panel">
      <h3><i class="bi bi-link-45deg"></i> Vincular tablas con llave foranea</h3>
      <p class="muted tiny">Crea relaciones entre tablas para mantener integridad referencial y evitar datos huerfanos.</p>

      <div class="fk-layout">
        <section class="fk-card">
          <h4>Crear relacion</h4>
          <form id="fkForm" class="grid-form">
            <label>
              Tabla origen
              <select id="fkTableSelect" name="tableName" required></select>
            </label>
            <label>
              Columna origen
              <select id="fkColumnSelect" name="columnName" required></select>
            </label>
            <label>
              Tabla destino
              <select id="fkRefTableSelect" name="referencedTable" required></select>
            </label>
            <label>
              Columna destino
              <select id="fkRefColumnSelect" name="referencedColumn" required></select>
            </label>
            <label>
              Regla al eliminar
              <select id="fkOnDelete" name="onDelete">
                <option value="RESTRICT">RESTRICT</option>
                <option value="CASCADE">CASCADE</option>
                <option value="SET NULL">SET NULL</option>
                <option value="NO ACTION">NO ACTION</option>
              </select>
            </label>
            <label>
              Regla al actualizar
              <select id="fkOnUpdate" name="onUpdate">
                <option value="CASCADE">CASCADE</option>
                <option value="RESTRICT">RESTRICT</option>
                <option value="SET NULL">SET NULL</option>
                <option value="NO ACTION">NO ACTION</option>
              </select>
            </label>
            <button type="submit" class="btn btn-primary"><i class="bi bi-link"></i> Crear FK</button>
          </form>
        </section>

        <section class="fk-card">
          <h4>Eliminar relacion</h4>
          <form id="fkDeleteForm" class="grid-form">
            <label>
              Tabla origen
              <select id="fkDeleteTableSelect" name="tableName" required></select>
            </label>
            <label>
              Constraint FK
              <select id="fkConstraintSelect" name="constraintName" required></select>
            </label>
            <button type="submit" class="btn btn-danger"><i class="bi bi-unlink"></i> Eliminar FK</button>
          </form>

          <h4>Relaciones actuales</h4>
          <ul id="fkList" class="fk-list"></ul>
        </section>
      </div>
    </article>
  </section>
</main>

<div id="toast"></div>

<div id="deleteModal" class="modal-overlay" aria-hidden="true">
  <div class="modal-card" role="dialog" aria-modal="true" aria-labelledby="deleteModalTitle">
    <div class="modal-icon"><i class="bi bi-exclamation-triangle"></i></div>
    <h3 id="deleteModalTitle">Confirmar eliminacion</h3>
    <p id="deleteModalText" class="modal-text"></p>
    <div class="modal-actions">
      <button id="cancelDeleteBtn" type="button" class="btn btn-ghost">Cancelar</button>
      <button id="confirmDeleteBtn" type="button" class="btn btn-danger">
        <i class="bi bi-trash3"></i>
        Si, eliminar
      </button>
    </div>
  </div>
</div>

<script>
  window.__APP_DATA__ = {
    tables: <%- JSON.stringify(tables) %>,
    sqlTypes: <%- JSON.stringify(sqlTypes) %>
  };
</script>
<script src="/js/app.js"></script>

<%- include('partials/footer') %>
